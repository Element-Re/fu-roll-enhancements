<div class="target-guide-ui">
    <section class="target-pool">

        <fieldset class="pending-target-list">
            <legend>{{localize "fu-roll-enhancements.guidedTargeting.dialog.pendingTargets.label"}}</legend>
            <div class="pending-target-entries">
                {{#each initialTargets}}
                    {{> "modules/fu-roll-enhancements/templates/partials/target-entry.hbs"}}
                {{/each}}
            </div>
        </fieldset>

        <fieldset class="enemies-list">
            <legend>{{localize "fu-roll-enhancements.guidedTargeting.dialog.enemies.label"}}</legend>
            {{#each validTargets.enemies}}
                {{> "modules/fu-roll-enhancements/templates/partials/target-entry.hbs"}}
            {{/each}}
        </fieldset>

        <fieldset class="allies-list">
            <legend>{{localize "fu-roll-enhancements.guidedTargeting.dialog.allies.label"}}</legend>
            {{#each validTargets.allies}}
                {{> "modules/fu-roll-enhancements/templates/partials/target-entry.hbs"}}
            {{/each}}
        </fieldset>

        {{#if validTargets.self}}
            <fieldset class="self-list">
                <legend>{{localize "fu-roll-enhancements.guidedTargeting.dialog.self.label"}}</legend>
                {{#each validTargets.self}}
                    {{> "modules/fu-roll-enhancements/templates/partials/target-entry.hbs"}}
                {{/each}}
            </fieldset>
        {{/if}}
    </section>
    <div class="legend">
        <span class="priority" data-tooltip="{{localize "fu-roll-enhancements.guidedTargeting.dialog.priority.hint"}}">
            <label>{{localize "fu-roll-enhancements.guidedTargeting.dialog.priority.label"}}</label>
        </span>
        <span class="recommended" data-tooltip="{{localize "fu-roll-enhancements.guidedTargeting.dialog.recommended.hint"}}">
            <label>{{localize "fu-roll-enhancements.guidedTargeting.dialog.recommended.label"}}</label>
        </span>
        <span class="valid" data-tooltip="{{localize "fu-roll-enhancements.guidedTargeting.dialog.valid.hint"}}">
            <label>{{localize "fu-roll-enhancements.guidedTargeting.dialog.valid.label"}}</label>
        </span>
        <span class="invalid" data-tooltip="{{localize "fu-roll-enhancements.guidedTargeting.dialog.invalid.hint"}}">
            <label>{{localize "fu-roll-enhancements.guidedTargeting.dialog.invalid.label"}}</label>
        </span>
    </div>
</div>
