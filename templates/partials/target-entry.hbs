<div data-token-id="{{token.id}}" class="target {{#if priority}}priority{{else if recommended}}recommended{{else if valid}}valid{{else}}invalid{{/if}}">
    <img src="{{thumbnail}}" class="thumbnail" alt="{{token.name}}" >
    <label>{{token.name}}{{#if (gt recommendationCount 1)}} <span>(x{{recommendationCount}})</span>{{/if}}</label>
    {{#each priorityReasons~}}
        {{#if icon}}<img class="priority-reason-icon" src="{{icon}}" alt="{{reason}}">{{/if}}
    {{~/each}}
</div>